# Frontend environment configuration
# Copy this file to `.env.local` or `.env` and adjust values per environment.

VITE_API_BASE_URL=https://localhost:3040
VITE_APP_URL=https://localhost:3000
VITE_TOKEN_STORAGE_KEY=THREADLY_ACCESS_TOKEN
VITE_USER_STORAGE_KEY=THREADLY_USER
VITE_ENABLE_BRAND_DETAIL_ENDPOINTS=true
VITE_API_WITH_CREDENTIALS=true
VITE_GOOGLE_CLIENT_ID=<google-web-client-id>
VITE_PAYSTACK_CARDHOLDER_NAME_MATCH_MODE=soft

# Keep frontend cardholder-name defaults aligned with the backend environment markers.
VITE_APP_ENV=development
VITE_DEPLOY_ENV=
VITE_NODE_ENV=

# Optional local HTTPS parity with production browser/payment behavior.
# When enabled, point these at your local TLS certificate files.
VITE_DEV_PORT=3000
VITE_DEV_HTTPS=false
VITE_DEV_HTTPS_CERT_PATH=./certs/localhost.pem
VITE_DEV_HTTPS_KEY_PATH=./certs/localhost-key.pem
